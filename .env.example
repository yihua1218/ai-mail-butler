# Server Configuration
PORT=3000
HOST=localhost
RUST_LOG=info,ai_mail_butler=debug
ADMIN_EMAIL=admin@example.com

# Database Configuration
DATABASE_URL=sqlite:data/data.sqlite

# Mail Configuration
SMTP_RELAY_HOST=smtp.your-server-address
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=your-smtp-user
SMTP_RELAY_PASS=your-smtp-pass
ASSISTANT_EMAIL=assistant@mail.example.com

# AI Configuration (e.g., LM Studio or OpenAI API)
AI_API_BASE_URL=http://localhost:1234/v1
AI_API_KEY=your-api-key
AI_MODEL_NAME=your-model-name

# Microsoft 365 OAuth Configuration (Optional, for Graph API Mail Sending)
M365_CLIENT_ID=your-client-id
M365_CLIENT_SECRET=your-client-secret
M365_TENANT_ID=your-tenant-id
