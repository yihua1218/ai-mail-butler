# Server Configuration
PORT=3000
HOST=localhost
# Public base URL used in magic login links sent by email.
# Set this to your public domain so recipients get a correct URL.
# Example: PUBLIC_URL=https://butler.example.com
PUBLIC_URL=http://localhost:3000
RUST_LOG=info,ai_mail_butler=debug
ADMIN_EMAIL=admin@example.com

# Database Configuration
DATABASE_URL=sqlite:data/data.sqlite

# Read-only / remote debug workflow
# READONLY_MODE=true redirects app writes into OVERLAY_DIR and blocks write APIs.
# Use these with a local SSHFS mount when debugging a remote spool or data snapshot.
READONLY_MODE=false
READONLY_BASE=
OVERLAY_DIR=data/overlay
REMOTE_DEBUG_SSHFS_ENABLED=false
# readonly = inspect a read-only SSHFS mount; overlay = pair SSHFS base with local OverlayFS/READONLY_MODE.
REMOTE_DEBUG_MODE=readonly
# Example: devuser@example.com:/opt/ai-mail-butler/data
REMOTE_DEBUG_REMOTE=
REMOTE_DEBUG_MOUNT_POINT=
REMOTE_DEBUG_OVERLAY_DIR=

# Mail Configuration
SMTP_RELAY_HOST=smtp.your-server-address
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=your-smtp-user
SMTP_RELAY_PASS=your-smtp-pass
ASSISTANT_EMAIL=assistant@mail.example.com

# AI Configuration (e.g., LM Studio or OpenAI API)
AI_API_BASE_URL=http://localhost:1234/v1
AI_API_KEY=your-api-key
AI_MODEL_NAME=your-model-name

# Microsoft 365 OAuth Configuration (Optional, for Graph API Mail Sending)
M365_CLIENT_ID=your-client-id
M365_CLIENT_SECRET=your-client-secret
M365_TENANT_ID=your-tenant-id
